MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=sameworld

QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_API_KEY=<qdrant-api-key>
QDRANT_COLLECTION=signals

UPSTASH_REDIS_URL=https://<region>-<name>.upstash.io
UPSTASH_REDIS_TOKEN=<upstash-rest-token>

GROQ_API_KEY=<groq-api-key>
# Optional, comma-separated: extra keys tried in round-robin when the primary hits its rate limit.
GROQ_FALLBACK_API_KEYS=<groq-api-key-2>,<groq-api-key-3>
GROQ_MODEL=llama-3.3-70b-versatile

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

CORS_ORIGINS=["http://localhost:3000"]
